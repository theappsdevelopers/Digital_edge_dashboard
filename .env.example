PORT=4000
# Dev/Preview → digital_edge_dev
MONGODB_URI_DEV=mongodb+srv://user:password@cluster.mongodb.net/digital_edge_dev
# Production → digital_edge_prod
MONGODB_URI_PROD=mongodb+srv://user:password@cluster.mongodb.net/digital_edge_prod
# Fallback if only one env is set (optional)
# MONGODB_URI=mongodb+srv://...

NODE_ENV=development

# Admin login (no signup)
ADMIN_EMAIL=admin
ADMIN_PASSWORD=admin

# JWT secret (use a long random string in production)
JWT_SECRET=your-jwt-secret-here
